
# Database 
POSTGRES_USER=bestiz_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=bestiz
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Server 
SERVER_PORT=4000
NODE_ENV=development

#  JWT 
# Generate strong secrets in production, e.g. `openssl rand -base64 64`
JWT_ACCESS_SECRET=replace_with_a_long_random_string_at_least_32_chars
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

#  Client 
CLIENT_PORT=5173
CLIENT_URL=http://localhost:5173

#  API base URL exposed to the client (Vite consumes VITE_* prefixed vars) 
VITE_API_BASE_URL=http://localhost:4000
